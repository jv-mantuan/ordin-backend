## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Rider
.idea/

# VS Code (keep launch.json and tasks.json tracked)
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# wwroot (temp files)
wwwroot/lib/
wwwroot/dist/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Npm & Yarn
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Paket dependency manager
.paket/
paket-files/

# JetBrains Rider
.ReSharper*/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# Visual Studio cache files
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono
mono_crash.*

# Nuget
*.nupkg
*.snupkg
packages/
*.nuget.props
*.nuget.targets

# Microsoft auto-generated files
**/Properties/launchSettings.json
*.dbmdl
*.jfm
*.pfx
*.publishsettings
*.pubxml
*.pubxml.user

# SQL local db
*.mdf
*.ldf

# Logs
*.log
*.tlog

# Coverage
coverage/
*.coverage
*.coveragexml
.coverage/
coverage.*.xml

# dotenv
.env
.env.*.local

# Cache
.cache/
*.cache
*~ 
!.editorconfig

# Temporary files
~$*
*.tmp
*.temp
*.bak
*.old

# OS files
.DS_Store
Thumbs.db

# Publish output
publish/
out/

# Test results
TestResults/
nunit-*.xml
*.trx

# CLI artifacts
*.pidb
*.svclog
*.scc

# Others
*.orig
*.rej
*.diff
*.orig

# SSL dev certs
*.pem
*.crt
*.key

# Rider plugins
.idea/

# Dotnet tools
.dotnet-tools.json

# Python virtual env (if mixed project)
venv/

# yaml locked files
*.runtimeconfig.dev.json

# Local settings
appsettings.Development.json
appsettings.Local.json
